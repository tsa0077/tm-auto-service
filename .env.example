# Turso Database (SQLite cloud)
TURSO_DATABASE_URL="libsql://your-db-name-your-org.turso.io"
TURSO_AUTH_TOKEN="your-turso-auth-token"

# NextAuth
AUTH_SECRET="CHANGE_ME_GENERATE_WITH_openssl_rand_base64_32"
AUTH_URL="https://your-domain.vercel.app"

# Public site URL (used for sitemap, SEO)
NEXT_PUBLIC_SITE_URL="https://your-domain.vercel.app"

# Storage (local | vercel-blob)
STORAGE_PROVIDER="vercel-blob"

# Vercel Blob (auto-configured by Vercel when you add Blob store)
BLOB_READ_WRITE_TOKEN="vercel_blob_..."

# SMTP / Email (optional – uncomment and configure)
# SMTP_HOST="smtp.example.com"
# SMTP_PORT="587"
# SMTP_USER="apikey"
# SMTP_PASS="SG.xxx"
# SMTP_FROM="noreply@tm-auto-service.fr"
